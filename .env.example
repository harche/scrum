# Scrum Master Workspace — Environment Setup
#
# This file documents the required configuration.
# Do NOT copy this to .env — the tools read from macOS Keychain and env vars directly.

# ── Jira Authentication ──────────────────────────────────────────────────────
#
# 1. Create a Jira API token at: https://id.atlassian.com/manage-profile/security/api-tokens
#
# 2. Store it in macOS Keychain:
#    security add-generic-password -s "JIRA_API_TOKEN" -a "your-username" -w "your-api-token"
#
# 3. Set your Jira email (or let it auto-detect from Keychain account / git config):
JIRA_EMAIL="you@example.com"

# ── GitHub Authentication ────────────────────────────────────────────────────
#
# Install the GitHub CLI and authenticate:
#   brew install gh
#   gh auth login
#
# The gh-activity.sh scripts use `gh api graphql` which reads auth from gh's config.

# ── Optional ─────────────────────────────────────────────────────────────────
#
# Override the default Jira board ID (default: 7845):
# JIRA_BOARD_ID=7845
